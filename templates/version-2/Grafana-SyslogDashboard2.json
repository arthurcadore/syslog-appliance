          "editorMode": "code",
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT\r\n  STR_TO_DATE(\r\n    CONCAT(YEAR(CURDATE()), '-', \r\n           CASE\r\n             WHEN SUBSTRING(datetime, 1, 3) = 'Jan' THEN '01'\r\n             WHEN SUBSTRING(datetime, 1, 3) = 'Feb' THEN '02'\r\n             WHEN SUBSTRING(datetime, 1, 3) = 'Mar' THEN '03'\r\n             WHEN SUBSTRING(datetime, 1, 3) = 'Apr' THEN '04'\r\n             WHEN SUBSTRING(datetime, 1, 3) = 'May' THEN '05'\r\n             WHEN SUBSTRING(datetime, 1, 3) = 'Jun' THEN '06'\r\n             WHEN SUBSTRING(datetime, 1, 3) = 'Jul' THEN '07'\r\n             WHEN SUBSTRING(datetime, 1, 3) = 'Aug' THEN '08'\r\n             WHEN SUBSTRING(datetime, 1, 3) = 'Sep' THEN '09'\r\n             WHEN SUBSTRING(datetime, 1, 3) = 'Oct' THEN '10'\r\n             WHEN SUBSTRING(datetime, 1, 3) = 'Nov' THEN '11'\r\n             WHEN SUBSTRING(datetime, 1, 3) = 'Dec' THEN '12'\r\n           END, \r\n           '-', \r\n           LPAD(TRIM(SUBSTRING(datetime, 5, 2)), 2, '0'), ' ',\r\n           SUBSTRING(datetime, 8, 2), ':', SUBSTRING(datetime, 11, 2), ':00'\r\n    ),\r\n    '%Y-%m-%d %H:%i:%s'\r\n  ) AS minute_interval,\r\n  COUNT(host) AS host_count\r\nFROM\r\n  logs\r\nGROUP BY\r\n  minute_interval\r\nORDER BY\r\n  minute_interval;",
          "refId": "A",
          "sql": {
            "columns": [
              {
                "parameters": [],
                "type": "function"
              }
            ],
            "groupBy": [
              {
                "property": {
                  "type": "string"
